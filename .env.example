# Alpaca API Configuration
# Copy this file to .env and fill in your credentials
# NEVER commit .env to version control!

# ============================================================================
# ALPACA API CREDENTIALS
# ============================================================================
# Get your API keys from: https://app.alpaca.markets/paper/dashboard/overview
# For paper trading, use the Paper Trading API keys
# For live trading, use the Live Trading API keys (USE WITH EXTREME CAUTION!)

ALPACA_API_KEY=your_api_key_here
ALPACA_SECRET_KEY=your_secret_key_here

# ============================================================================
# TRADING MODE
# ============================================================================
# CRITICAL: Start with paper trading enabled!
# Paper Trading URL: https://paper-api.alpaca.markets
# Live Trading URL: https://api.alpaca.markets

ENABLE_PAPER_TRADING=True

# Optional: Override base URL (auto-detected based on ENABLE_PAPER_TRADING)
# ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ============================================================================
# API CONFIGURATION
# ============================================================================
FLASK_SECRET_KEY=change_this_to_a_random_secret_key_in_production
FLASK_PORT=5000
FLASK_DEBUG=False

# ============================================================================
# SAFETY LIMITS (Circuit Breaker Configuration)
# ============================================================================
# These limits protect you from excessive losses and overtrading

# Maximum number of trades per day
MAX_DAILY_TRADES=50

# Maximum percentage of portfolio per position (e.g., 15.0 = 15%)
MAX_POSITION_SIZE_PERCENT=15.0

# Stop trading if daily loss exceeds this percentage (e.g., 5.0 = 5%)
MAX_DAILY_LOSS_PERCENT=5.0

# Minimum account balance to maintain (in dollars)
MIN_ACCOUNT_BALANCE=1000.0

# ============================================================================
# RATE LIMITING
# ============================================================================
# Alpaca allows 200 requests per minute
API_RATE_LIMIT=200

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=INFO
LOG_FILE=trading_bot.log

# ============================================================================
# QUICK START GUIDE
# ============================================================================
# 1. Sign up for Alpaca: https://alpaca.markets
# 2. Get your Paper Trading API keys from the dashboard
# 3. Copy this file to .env: cp .env.example .env
# 4. Fill in your ALPACA_API_KEY and ALPACA_SECRET_KEY
# 5. Keep ENABLE_PAPER_TRADING=True for testing
# 6. Run: python api_server.py
# 7. Open index.html in your browser
# 8. Click "Start Simulation" to begin trading
#
# ⚠️  IMPORTANT: Test thoroughly in paper trading before going live!
